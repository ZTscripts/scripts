-- Custom UI element builders styled to match the hub theme
local function AddToggle(parent, text, defaultState, callback)
    local state = defaultState
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 0, 36)
    btn.BackgroundColor3 = C.cardBg
    btn.BorderSizePixel = 0
    btn.Font = Enum.Font.GothamBold
    btn.Text = text .. " — " .. (state and "[ ON ]" or "[ OFF ]")
    btn.TextColor3 = state and C.green or C.textSec
    btn.TextSize = 11
    btn.AutoButtonColor = false
    btn.Parent = parent

    local corner = Instance.new("UICorner", btn)
    corner.CornerRadius = UDim.new(0, 6)

    local stroke = Instance.new("UIStroke", btn)
    stroke.Color = C.border
    stroke.Thickness = 1

    btn.MouseButton1Click:Connect(function()
        state = not state
        btn.Text = text .. " — " .. (state and "[ ON ]" or "[ OFF ]")
        btn.TextColor3 = state and C.green or C.textSec
        callback(state)
    end)
end

local function AddSlider(parent, text, min, max, defaultVal, callback)
    local val = defaultVal

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 48)
    frame.BackgroundColor3 = C.cardBg
    frame.BorderSizePixel = 0
    frame.Parent = parent

    local corner = Instance.new("UICorner", frame)
    corner.CornerRadius = UDim.new(0, 6)

    local stroke = Instance.new("UIStroke", frame)
    stroke.Color = C.border
    stroke.Thickness = 1

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -120, 0, 20)
    label.Position = UDim2.new(0, 12, 0, 4)
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.GothamBold
    label.Text = text
    label.TextColor3 = C.textPri
    label.TextSize = 11
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = frame

    local valLabel = Instance.new("TextLabel")
    valLabel.Size = UDim2.new(0, 100, 0, 20)
    valLabel.Position = UDim2.new(1, -112, 0, 4)
    valLabel.BackgroundTransparency = 1
    valLabel.Font = Enum.Font.GothamBold
    valLabel.Text = tostring(val)
    valLabel.TextColor3 = C.accentGlow
    valLabel.TextSize = 11
    valLabel.TextXAlignment = Enum.TextXAlignment.Right
    valLabel.Parent = frame

    local minusBtn = Instance.new("TextButton")
    minusBtn.Size = UDim2.new(0, 24, 0, 20)
    minusBtn.Position = UDim2.new(0, 12, 0, 24)
    minusBtn.BackgroundColor3 = C.bg3
    minusBtn.Text = "-"
    minusBtn.TextColor3 = C.textPri
    minusBtn.Font = Enum.Font.GothamBold
    minusBtn.Parent = frame
    local mCorner = Instance.new("UICorner", minusBtn)
    mCorner.CornerRadius = UDim.new(0, 4)

    local plusBtn = Instance.new("TextButton")
    plusBtn.Size = UDim2.new(0, 24, 0, 20)
    plusBtn.Position = UDim2.new(1, -36, 0, 24)
    plusBtn.BackgroundColor3 = C.bg3
    plusBtn.Text = "+"
    plusBtn.TextColor3 = C.textPri
    plusBtn.Font = Enum.Font.GothamBold
    plusBtn.Parent = frame
    local pCorner = Instance.new("UICorner", plusBtn)
    pCorner.CornerRadius = UDim.new(0, 4)

    local barBg = Instance.new("Frame")
    barBg.Size = UDim2.new(1, -84, 0, 6)
    barBg.Position = UDim2.new(0, 42, 0, 31)
    barBg.BackgroundColor3 = C.bg3
    barBg.BorderSizePixel = 0
    barBg.Parent = frame

    local barFill = Instance.new("Frame")
    local pct = (val - min) / (max - min)
    barFill.Size = UDim2.new(pct, 0, 1, 0)
    barFill.BackgroundColor3 = C.accent
    barFill.BorderSizePixel = 0
    barFill.Parent = barBg

    local function updateVal(newVal)
        val = math.clamp(newVal, min, max)
        valLabel.Text = tostring(val)
        local p = (val - min) / (max - min)
        barFill.Size = UDim2.new(p, 0, 1, 0)
        callback(val)
    end

    minusBtn.MouseButton1Click:Connect(function()
        local step = (max - min) >= 100 and 10 or 1
        updateVal(val - step)
    end)

    plusBtn.MouseButton1Click:Connect(function()
        local step = (max - min) >= 100 and 10 or 1
        updateVal(val + step)
    end)
end

