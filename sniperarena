function getClosestPlayerInstance()
    local target = nil
    local shortestDistance = math.huge
    local camera = workspace.CurrentCamera
    if not camera then return nil end
    
    local mouseLocation = UserInputService:GetMouseLocation()

    for _, player in pairs(Players:GetPlayers()) do
        if not isPlayerAliveAndActive(player) then continue end
        if teamCheckEnabled and player.Team == LocalPlayer.Team then continue end

        local char = player.Character
        local part = char:FindFirstChild(aimTargetPart)

        if part then
            local screenPos, onScreen = camera:WorldToViewportPoint(part.Position)
            if onScreen then
                local distance = (Vector2.new(screenPos.X, screenPos.Y) - mouseLocation).Magnitude
                if distance < shortestDistance and distance <= aimRadius then
                    
                    if wallCheckEnabled then
                        local raycastParams = RaycastParams.new()
                        raycastParams.FilterType = Enum.RaycastFilterType.Exclude
                        raycastParams.FilterDescendantsInstances = {LocalPlayer.Character, char, camera}
                        raycastParams.IgnoreWater = true
                        
                        local rayResult = workspace:Raycast(camera.CFrame.Position, part.Position - camera.CFrame.Position, raycastParams)
                        if rayResult and rayResult.Instance and not rayResult.Instance:IsDescendantOf(char) then 
                            continue 
                        end
                    end

                    target = part
                    shortestDistance = distance
                end
            end
        end
    end
    return target
end

function getClosestPlayerScreen()
    local targetPart = getClosestPlayerInstance()
    if targetPart then
        local camera = workspace.CurrentCamera
        local screenPos, _ = camera:WorldToViewportPoint(targetPart.Position)
        return screenPos
    end
    return nil
end

function systemUpdate()
    local camera = workspace.CurrentCamera
    if not camera then return end

    if fovCircleDraw then
        fovCircleDraw.Position = UserInputService:GetMouseLocation()
        fovCircleDraw.Radius = aimRadius
        fovCircleDraw.Visible = fovVisible
    end

    local isRightClickActive = UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)

    if aimbotEnabled and isRightClickActive then
        local targetScreenPos = getClosestPlayerScreen()
        if targetScreenPos and mousemoverel then
            local mouseLocation = UserInputService:GetMouseLocation()
            local deltaX = (targetScreenPos.X - mouseLocation.X) / aimSmoothness
            local deltaY = (targetScreenPos.Y - mouseLocation.Y) / aimSmoothness
            mousemoverel(deltaX, deltaY)
        end
    end

    if triggerbotEnabled and isRightClickActive then
        if (os.clock() - lastRightClickTime) > 0.25 then
            local mouseLocation = UserInputService:GetMouseLocation()
            local unitRay = camera:ViewportPointToRay(mouseLocation.X, mouseLocation.Y)
            
            local rayParams = RaycastParams.new()
            rayParams.FilterType = Enum.RaycastFilterType.Exclude
            rayParams.FilterDescendantsInstances = {LocalPlayer.Character, camera}
            
            local rayResult = workspace:Raycast(unitRay.Origin, unitRay.Direction * 5000, rayParams)
            if rayResult and rayResult.Instance then
                local targetChar = rayResult.Instance:FindFirstAncestorOfClass("Model")
                if targetChar then
                    local targetPlr = Players:GetPlayerFromCharacter(targetChar)
                    
                    if targetPlr and isPlayerAliveAndActive(targetPlr) then
                        if not (teamCheckEnabled and targetPlr.Team == LocalPlayer.Team) then
                            mouse1press()
                            task.wait(0.02)
                            mouse1release()
                            task.wait(triggerbotDelay)
                        end
                    end
                end
            end
        end
    end
end

function manageConnections()
    if aimbotEnabled or fovVisible or triggerbotEnabled then
        if not mainRenderConn then
            mainRenderConn = RunService.RenderStepped:Connect(systemUpdate)
        end
        if not inputBeganConn then
            inputBeganConn = UserInputService.InputBegan:Connect(function(input, processed)
                if not processed and input.UserInputType == Enum.UserInputType.MouseButton2 then
                    lastRightClickTime = os.clock()
                end
            end)
        end
    else
        if mainRenderConn then mainRenderConn:Disconnect(); mainRenderConn = nil end
        if inputBeganConn then inputBeganConn:Disconnect(); inputBeganConn = nil end
        if fovCircleDraw then fovCircleDraw.Visible = false end
    end
end

function buildESPFrame(player)
    local holder = Instance.new("Frame")
    holder.Name = "ESP_" .. player.Name
    holder.BackgroundTransparency = 1
    holder.BorderSizePixel = 0
    holder.Size = UDim2.new(0, 0, 0, 0)
    holder.Parent = ScreenGui

    local function makeLine()
        local f = Instance.new("Frame")
        f.BackgroundColor3 = espColor
        f.BorderSizePixel = 0
        f.ZIndex = 21
        f.Parent = holder
        return f
    end

    local nameTag = Instance.new("TextLabel")
    nameTag.BackgroundTransparency = 1
    nameTag.TextColor3 = espNameColor
    nameTag.TextStrokeTransparency = 0.5
    nameTag.Font = Enum.Font.GothamBold
    nameTag.TextSize = 11
    nameTag.Text = player.Name
    nameTag.Size = UDim2.new(0, 120, 0, 14)
    nameTag.TextXAlignment = Enum.TextXAlignment.Center
    nameTag.ZIndex = 22
    nameTag.Visible = false
    nameTag.Parent = ScreenGui

    return {
        holder = holder,
        top = makeLine(),
        bot = makeLine(),
        left = makeLine(),
        right = makeLine(),
        nameTag = nameTag
    }
end

function destroyESPFor(player)
    local d = espData[player]
    if not d then return end
    if d.holder  and d.holder.Parent  then d.holder:Destroy()  end
    if d.nameTag and d.nameTag.Parent then d.nameTag:Destroy() end
    espData[player] = nil
end

function updateESP()
    local camera = workspace.CurrentCamera
    if not camera then return end

    for cachedPlayer, _ in pairs(espData) do
        if not Players:FindFirstChild(cachedPlayer.Name) then
            destroyESPFor(cachedPlayer)
        end
    end

    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end

        if not isPlayerAliveAndActive(player) then
            local d = espData[player]
            if d then
                d.holder.Visible = false
                d.nameTag.Visible = false
            end
            continue
        end

        local char = player.Character
        local hrp = char:FindFirstChild("HumanoidRootPart")

        if not espData[player] then espData[player] = buildESPFrame(player) end
        local d = espData[player]

        local pos = hrp.Position
        local distance = (camera.CFrame.Position - pos).Magnitude
        if distance > maxEspDistance then
            d.holder.Visible = false
            d.nameTag.Visible = false
            continue
        end

        local topSP = camera:WorldToViewportPoint(pos + Vector3.new(0, 3.5, 0))
        local botSP = camera:WorldToViewportPoint(pos - Vector3.new(0, 3.2, 0))

        if topSP.Z > 0 and botSP.Z > 0 then
            local topY = math.min(topSP.Y, botSP.Y)
            local botY = math.max(topSP.Y, botSP.Y)
            local h = botY - topY
            local w = h * 0.45
            local x = (topSP.X + botSP.X) / 2 - (w / 2)

            local t = espThickness
            d.top.BackgroundColor3 = espColor
            d.bot.BackgroundColor3 = espColor
            d.left.BackgroundColor3 = espColor
            d.right.BackgroundColor3 = espColor
            d.nameTag.TextColor3 = espNameColor

            d.holder.Position = UDim2.new(0, x, 0, topY)
            d.holder.Size = UDim2.new(0, w, 0, h)
            d.holder.Visible = boxEspEnabled

            if boxEspEnabled then
                d.top.Size = UDim2.new(1, 0, 0, t); d.top.Position = UDim2.new(0, 0, 0, 0)
                d.bot.Size = UDim2.new(1, 0, 0, t); d.bot.Position = UDim2.new(0, 0, 1, -t)
                d.left.Size = UDim2.new(0, t, 1, 0); d.left.Position = UDim2.new(0, 0, 0, 0)
                d.right.Size = UDim2.new(0, t, 1, 0); d.right.Position = UDim2.new(1, -t, 0, 0)
            end

            d.nameTag.Position = UDim2.new(0, x + (w / 2) - 60, 0, topY - 16)
            d.nameTag.Visible = nameEspEnabled
        else
            d.holder.Visible = false
            d.nameTag.Visible = false
        end
    end
end

function manageESPState()
    if boxEspEnabled or nameEspEnabled then
        if not espRenderConn then espRenderConn = RunService.RenderStepped:Connect(updateESP) end
    else
        if espRenderConn then espRenderConn:Disconnect(); espRenderConn = nil end
        for player, _ in pairs(espData) do destroyESPFor(player) end
        espData = {}
    end
end

