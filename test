local function makeStatCard(xScale, xOff, wScale, wOff, yOff, title_, value_, vcol)
	local c = Instance.new("Frame")
	c.Size = UDim2.new(wScale, wOff, 0, 56)
	c.Position = UDim2.new(xScale, xOff, 0, yOff)
	c.BackgroundColor3 = C.bg3
	c.BorderSizePixel = 0
	c.Parent = Home_Page
	corner(c, 8)
	stroke(c, C.border)

	lbl(c, {
		text  = title_,
		font  = Enum.Font.GothamBold,
		size  = 9,
		color = C.textMuted,
		sz    = UDim2.new(1, -16, 0, 12),
		pos   = UDim2.new(0, 12, 0, 10),
	})
	lbl(c, {
		text  = value_,
		font  = Enum.Font.GothamSemibold,
		size  = 11,
		color = vcol or C.textPri,
		sz    = UDim2.new(1, -16, 0, 22),
		pos   = UDim2.new(0, 12, 0, 26),
	})
	return c
end

