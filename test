local function switchTab(index)
	for idx, t in ipairs(tabBtns) do setTabActive(t, idx == index) end
	for idx, p in ipairs(pages)   do p.Visible = (idx == index) end
end

for idx, t in ipairs(tabBtns) do
	t.btn.MouseButton1Click:Connect(function() switchTab(idx) end)
end

