            end
        end)

        function getClosestPlayerInstance()
            local target = nil
            local shortestDistance = math.huge
            local camera = workspace.CurrentCamera
            if not camera then return nil end
            
            local mouseLocation = UserInputService:GetMouseLocation()

            for _, player in pairs(Players:GetPlayers()) do
                if not isPlayerAliveAndActive(player) then continue end
                if teamCheckEnabled and player.Team == LocalPlayer.Team then continue end

                local char = player.Character
                local part = char:FindFirstChild(aimTargetPart)

                if part then
                    local screenPos, onScreen = camera:WorldToViewportPoint(part.Position)
                    if onScreen then
                        local distance = (Vector2.new(screenPos.X, screenPos.Y) - mouseLocation).Magnitude
                        if distance < shortestDistance and distance <= aimRadius then
                            
                            if wallCheckEnabled then
                                local raycastParams = RaycastParams.new()
                                raycastParams.FilterType = Enum.RaycastFilterType.Exclude
                                raycastParams.FilterDescendantsInstances = {LocalPlayer.Character, char, camera}
                                raycastParams.IgnoreWater = true
                                
                                local rayResult = workspace:Raycast(camera.CFrame.Position, part.Position - camera.CFrame.Position, raycastParams)
                                if rayResult and rayResult.Instance and not rayResult.Instance:IsDescendantOf(char) then 
                                    continue 
                                end
                            end

                            target = part
                            shortestDistance = distance
                        end
                    end
                end
            end
            return target
        end

        function getClosestPlayerScreen()
            local targetPart = getClosestPlayerInstance()
            if targetPart then
                local camera = workspace.CurrentCamera
                local screenPos, _ = camera:WorldToViewportPoint(targetPart.Position)
                return screenPos
            end
            return nil
        end

        function systemUpdate()
            local camera = workspace.CurrentCamera
            if not camera then return end

            if fovCircleDraw then
                fovCircleDraw.Position = UserInputService:GetMouseLocation()
                fovCircleDraw.Radius = aimRadius
                fovCircleDraw.Visible = fovVisible
            end

            local isRightClickActive = UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)

            if aimbotEnabled and isRightClickActive then
                local targetScreenPos = getClosestPlayerScreen()
                if targetScreenPos and mousemoverel then
                    local mouseLocation = UserInputService:GetMouseLocation()
                    local deltaX = (targetScreenPos.X - mouseLocation.X) / aimSmoothness
                    local deltaY = (targetScreenPos.Y - mouseLocation.Y) / aimSmoothness
                    mousemoverel(deltaX, deltaY)
                end
            end

            if triggerbotEnabled and isRightClickActive then
                if (os.clock() - lastRightClickTime) > 0.25 then
                    local mouseLocation = UserInputService:GetMouseLocation()
                    local unitRay = camera:ViewportPointToRay(mouseLocation.X, mouseLocation.Y)
                    
                    local rayParams = RaycastParams.new()
                    rayParams.FilterType = Enum.RaycastFilterType.Exclude
                    rayParams.FilterDescendantsInstances = {LocalPlayer.Character, camera}
                    
                    local rayResult = workspace:Raycast(unitRay.Origin, unitRay.Direction * 5000, rayParams)
                    if rayResult and rayResult.Instance then
                        local targetChar = rayResult.Instance:FindFirstAncestorOfClass("Model")
                        if targetChar then
                            local targetPlr = Players:GetPlayerFromCharacter(targetChar)
                           
                            if targetPlr and isPlayerAliveAndActive(targetPlr) then
                                if not (teamCheckEnabled and targetPlr.Team == LocalPlayer.Team) then
                                    mouse1press()
                                    task.wait(0.02)
                                    mouse1release()
                                    task.wait(triggerbotDelay)
                                end
                            end
                        end
                    end
                end
            end
        end

        function manageConnections()
