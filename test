		local d = 0.46 + (idx - 1) * 0.07
		t.ico.TextTransparency  = 1
		t.tlbl.TextTransparency = 1
		local origY = t.btn.Position.Y.Offset
		t.btn.Position = UDim2.new(t.btn.Position.X.Scale, t.btn.Position.X.Offset, 0, origY + 10)
		task.delay(d, function()
			local ri = TweenInfo.new(0.38, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
			tween(t.btn, ri, { Position = UDim2.new(t.btn.Position.X.Scale, t.btn.Position.X.Offset, 0, origY) })
			tween(t.ico,  ri, { TextTransparency = 0 })
			tween(t.tlbl, ri, { TextTransparency = 0 })
		end)
	end

	local homeChildren = {}
	for _, child in pairs(Home_Page:GetChildren()) do
		if child:IsA("Frame") then table.insert(homeChildren, child) end
	end
	table.sort(homeChildren, function(a, b) return a.Position.Y.Offset < b.Position.Y.Offset end)

	for idx, card in ipairs(homeChildren) do
		if not card then continue end 
		local d = 0.52 + (idx - 1) * 0.08
		local origBg = card:IsA("GuiObject") and card.BackgroundTransparency or 0
		local origY  = card.Position.Y.Offset
		
		card.BackgroundTransparency = 1
		card.Position = UDim2.new(card.Position.X.Scale, card.Position.X.Offset, card.Position.Y.Scale, origY - 10)
		
		task.delay(d, function()
			if not card or not card.Parent then return end
			local ri = TweenInfo.new(0.42, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
			tween(card, ri, {
				BackgroundTransparency = origBg,
				Position = UDim2.new(card.Position.X.Scale, card.Position.X.Offset, card.Position.Y.Scale, origY),
			})
			for _, child in pairs(card:GetDescendants()) do
				if child:IsA("TextLabel") then
					child.TextTransparency = 1
					task.delay(0.1, function() if child and child.Parent then tween(child, TweenInfo.new(0.28, Enum.EasingStyle.Quad), { TextTransparency = 0 }) end end)
				elseif child:IsA("ImageLabel") then
					child.ImageTransparency = 1
					task.delay(0.1, function() if child and child.Parent then tween(child, TweenInfo.new(0.28, Enum.EasingStyle.Quad), { ImageTransparency = 0 }) end end)
				end
			end
		end)
	end

	task.delay(1.2, function()
		if IsSupported then
			showLoadPrompt(GameEntry)
		else
			showToast("Game not supported", GameName .. " has no script yet.", "warn")
		end
	end)
end
