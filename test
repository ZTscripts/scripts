local function makeGameRow(placeId, entry, order)
	local isCurrent = (placeId == PlaceId)
	local rowIcon = "https://www.roblox.com/asset-thumbnail/image?assetId=" .. tostring(placeId) .. "&width=150&height=150&format=png"

	local row = Instance.new("Frame")
	row.Size = UDim2.new(1, 0, 0, 60)
	row.BackgroundColor3 = isCurrent and Color3.fromRGB(28, 32, 28) or C.bg3
	row.BorderSizePixel = 0
	row.LayoutOrder = order
	row.Parent = Games_Page
	corner(row, 10)

	if isCurrent then
		stroke(row, C.green, 1)
	else
		stroke(row, C.border)
	end

	local thumb = Instance.new("ImageLabel")
	thumb.Size = UDim2.new(0, 40, 0, 40)
	thumb.Position = UDim2.new(0, 12, 0.5, -20)
	thumb.BackgroundColor3 = C.bg4
	thumb.Image = (isCurrent and GameIconId ~= "rbxassetid://0") and GameIconId or rowIcon
	thumb.ScaleType = Enum.ScaleType.Crop
	thumb.BorderSizePixel = 0
	thumb.Parent = row
	corner(thumb, 7)

	lbl(row, {
		text  = entry.name,
		font  = Enum.Font.GothamSemibold,
		size  = 13,
		color = C.textPri,
		sz    = UDim2.new(1, -240, 0, 20),
		pos   = UDim2.new(0, 62, 0, 10),
	})

	if isCurrent then
		local curTag = Instance.new("Frame")
		curTag.Size = UDim2.new(0, 82, 0, 17)
		curTag.Position = UDim2.new(0, 62, 0, 34)
		curTag.BackgroundColor3 = C.greenDim
		curTag.BorderSizePixel = 0
		curTag.Parent = row
		corner(curTag, 4)

		local curTxt = Instance.new("TextLabel")
		curTxt.Size = UDim2.new(1, 0, 1, 0)
		curTxt.BackgroundTransparency = 1
		curTxt.Text = "Current game"
		curTxt.TextColor3 = C.green
		curTxt.Font = Enum.Font.GothamBold
		curTxt.TextSize = 9
		curTxt.Parent = curTag
	else
		lbl(row, {
			text  = "ID " .. tostring(placeId),
			size  = 10,
			color = C.textMuted,
			sz    = UDim2.new(1, -140, 0, 16),
			pos   = UDim2.new(0, 62, 0, 34),
		})
	end

	local loadBtn = Instance.new("TextButton")
	loadBtn.Size = UDim2.new(0, 72, 0, 30)
	loadBtn.Position = UDim2.new(1, -86, 0.5, -15)
	loadBtn.BackgroundColor3 = isCurrent and C.green or C.bg4
	loadBtn.Text = isCurrent and "Here" or "Go"
	loadBtn.TextColor3 = isCurrent and C.accentText or C.textSec
	loadBtn.Font = Enum.Font.GothamBold
	loadBtn.TextSize = 11
	loadBtn.Parent = row
	corner(loadBtn, 7)
	if not isCurrent then stroke(loadBtn, C.border) end

	if isCurrent then
		local executeBtn = Instance.new("TextButton")
		executeBtn.Size = UDim2.new(0, 72, 0, 30)
		executeBtn.Position = UDim2.new(1, -166, 0.5, -15)
		executeBtn.BackgroundColor3 = C.accent
		executeBtn.Text = "Load"
		executeBtn.TextColor3 = C.accentText
		executeBtn.Font = Enum.Font.GothamBold
		executeBtn.TextSize = 11
		executeBtn.Parent = row
		corner(executeBtn, 7)

		executeBtn.MouseEnter:Connect(function()
			tween(executeBtn, FAST, { BackgroundColor3 = Color3.fromRGB(220, 220, 220) })
		end)
		executeBtn.MouseLeave:Connect(function()
			tween(executeBtn, FAST, { BackgroundColor3 = C.accent })
		end)
		executeBtn.MouseButton1Click:Connect(function()
			showToast("Script Activated", "WesHub UI is ready to use.", "info")
			if entry.callback and type(entry.callback) == "function" then
				task.spawn(entry.callback)
			end
		end)
	end

	loadBtn.MouseEnter:Connect(function()
		tween(loadBtn, FAST, { BackgroundColor3 = isCurrent and Color3.fromRGB(76, 185, 105) or C.bg3 })
		if not isCurrent then loadBtn.TextColor3 = C.textPri end
	end)
	loadBtn.MouseLeave:Connect(function()
		tween(loadBtn, FAST, { BackgroundColor3 = isCurrent and Color3.fromRGB(76, 185, 105) or C.bg4 })
		if not isCurrent then loadBtn.TextColor3 = C.textSec end
	end)
	loadBtn.MouseButton1Click:Connect(function()
		if isCurrent then
			showToast("Already here", "You're already in " .. entry.name .. ".", "warn")
			return
		end
		showToast("Teleporting…", "Joining " .. entry.name, "info")
		task.delay(0.6, function()
			local ok, err = pcall(function() TeleportService:Teleport(placeId, LocalPlayer) end)
			if not ok then showToast("Teleport failed", tostring(err):sub(1, 48), "error") end
		end)
	end)

	return row
end

