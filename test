        local function destroyESPFor(player)
            local d = espData[player]
            if not d then return end
            if d.holder  and d.holder.Parent  then d.holder:Destroy()  end
            if d.nameTag and d.nameTag.Parent then d.nameTag:Destroy() end
            espData[player] = nil
        end

        local function destroyAllESP()
            for player, _ in pairs(espData) do
                destroyESPFor(player)
            end
            espData = {}
        end

        local TOP_OFFSET = 3.5   
        local BOT_OFFSET = 3.2   
        local WIDTH_RATIO = 0.45 

        local function getScreenBounds(char, camera)
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if not hrp then return nil end

            local distance = (camera.CFrame.Position - hrp.Position).Magnitude
            if distance > MAX_ESP_DISTANCE then return nil end

            local pos = hrp.Position
            local topSP = camera:WorldToViewportPoint(pos + Vector3.new(0,  TOP_OFFSET, 0))
            local botSP = camera:WorldToViewportPoint(pos - Vector3.new(0,  BOT_OFFSET, 0))

            if topSP.Z <= 0 or botSP.Z <= 0 then return nil end

            local topY = math.min(topSP.Y, botSP.Y)
            local botY = math.max(topSP.Y, botSP.Y)
            local screenH = botY - topY
            if screenH < 5 then return nil end  

            local screenW = screenH * WIDTH_RATIO
            local centerX = (topSP.X + botSP.X) / 2
            local pad = 2
            
            return  centerX - screenW / 2 - pad, topY - pad, screenW + pad * 2, screenH + pad * 2
        end

        local function updateESP()
            local camera = workspace.CurrentCamera
            if not camera then return end
            for cachedPlayer, _ in pairs(espData) do
                if not Players:FindFirstChild(cachedPlayer.Name) then
                    destroyESPFor(cachedPlayer)
                end
            end

            for _, player in pairs(Players:GetPlayers()) do
                if player == LocalPlayer then continue end
                if not isPlayerAliveAndActive(player) then
                    local d = espData[player]
                    if d then
                        d.holder.Visible  = false
                        d.nameTag.Visible = false
                    end
                    continue
                end

                local char = player.Character

                if not espData[player] then
                    espData[player] = buildESPFrame(player)
                end
                local d = espData[player]

                local x, y, w, h = getScreenBounds(char, camera)

                if not x then
                    d.holder.Visible  = false
                    d.nameTag.Visible = false
                    continue
                end

                local t = ESP_THICK

                d.top.BackgroundColor3 = ESP_COLOR
                d.bot.BackgroundColor3 = ESP_COLOR
                d.left.BackgroundColor3 = ESP_COLOR
                d.right.BackgroundColor3 = ESP_COLOR
                d.nameTag.TextColor3 = ESP_NAME_COL

                d.holder.Position = UDim2.new(0, x, 0, y)
                d.holder.Size     = UDim2.new(0, w, 0, h)
                d.holder.Visible  = boxEspEnabled

                if boxEspEnabled then
                    d.top.Position = UDim2.new(0, 0, 0, 0)
                    d.top.Size = UDim2.new(1, 0, 0, t)
                    d.bot.Position = UDim2.new(0, 0, 1, -t)
                    d.bot.Size = UDim2.new(1, 0, 0, t)
                    d.left.Position = UDim2.new(0, 0, 0, 0)
                    d.left.Size = UDim2.new(0, t, 1, 0)
                    d.right.Position = UDim2.new(1, -t, 0, 0)
                    d.right.Size = UDim2.new(0, t, 1, 0)
                end

                d.nameTag.Position = UDim2.new(0, x + w / 2 - 60, 0, y - 16)
                d.nameTag.Visible  = nameEspEnabled
            end
        end

        local function manageESPState()
            if boxEspEnabled or nameEspEnabled then
                if not espRenderConn then
                    espRenderConn = RunService.RenderStepped:Connect(updateESP)
                end
                if not espAddedConn then
                    espAddedConn = Players.PlayerAdded:Connect(function(p) end)
                end
                if not espRemovingConn then
                    espRemovingConn = Players.PlayerRemoving:Connect(function(p)
                        destroyESPFor(p)
                    end)
                end
            else
                if espRenderConn   then espRenderConn:Disconnect(); espRenderConn   = nil end
                if espAddedConn    then espAddedConn:Disconnect(); espAddedConn    = nil end
                if espRemovingConn then espRemovingConn:Disconnect(); espRemovingConn = nil end
                destroyAllESP()
            end
        end

        local playerAddedConn = Players.PlayerAdded:Connect(function(player)
            if highlightsEnabled then highlightCharacter(player) end
        end)

        local playerRemovingConn = Players.PlayerRemoving:Connect(function(player)
            if activeHighlights[player] then
                activeHighlights[player]:Destroy()
                activeHighlights[player] = nil
            end
        end)

        local baseCleanUp = Menu.OnClose or function() end
        Menu.OnClose = function()
            togglePlatform(false)
            toggleHighlights(false)
            
            boxEspEnabled = false
            nameEspEnabled = false
            manageESPState()
            
            if playerAddedConn then playerAddedConn:Disconnect() end
            if playerRemovingConn then playerRemovingConn:Disconnect() end
            baseCleanUp()
        end

        Menu.AddHeader(ScriptTab, "Player Modifications")
        Menu.AddToggle(ScriptTab, "spawn platform (platform after)", false, function(state)
            togglePlatform(state)
        end)
        Menu.AddButton(ScriptTab, "move to safe spot", function()
            teleportPlayer()
        end)

        Menu.AddHeader(VisualTab, "Roblox Highlight ESP")
        Menu.AddToggle(VisualTab, "Player ESP Highlights", false, function(state)
            toggleHighlights(state)
        end)

        Menu.AddHeader(VisualTab, "Drawing API ESP (Main)")
        Menu.AddToggle(VisualTab, "2D Box ESP", false, function(state)
            boxEspEnabled = state
            manageESPState()
        end)
        Menu.AddToggle(VisualTab, "Name ESP", false, function(state)
            nameEspEnabled = state
            manageESPState()
        end)

        Menu.AddHeader(ConfigTab, "ESP Configuration")
        Menu.AddSlider(ConfigTab, "Line Thickness (px)", 1, 6, ESP_THICK, function(val)
            ESP_THICK = val
        end)
        Menu.AddSlider(ConfigTab, "Max Render Distance", 100, 3000, MAX_ESP_DISTANCE, function(val)
            MAX_ESP_DISTANCE = val
        end)

        Menu.AddHeader(ConfigTab, "Theme Customization")
        Menu.AddButton(ConfigTab, "Cycle Box ESP Color", function()
            boxColorIdx = (boxColorIdx % #COLOR_PRESETS) + 1
            ESP_COLOR = COLOR_PRESETS[boxColorIdx].color
            showToast("Theme Updated", "Box ESP set to " .. COLOR_PRESETS[boxColorIdx].name, "info")
        end)
        Menu.AddButton(ConfigTab, "Cycle Name Tag Color", function()
            nameColorIdx = (nameColorIdx % #COLOR_PRESETS) + 1
            ESP_NAME_COL = COLOR_PRESETS[nameColorIdx].color
            showToast("Theme Updated", "Name Tag ESP set to " .. COLOR_PRESETS[nameColorIdx].name, "info")
        end)

        showToast("Paint And SEEK!", "All features loaded successfully!", "info")
    end
},

