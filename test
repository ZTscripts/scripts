local function lbl(parent, props)
	local t = Instance.new("TextLabel")
	t.BackgroundTransparency = 1
	t.Font            = props.font  or Enum.Font.Gotham
	t.TextSize        = props.size  or 13
	t.TextColor3      = props.color or C.textPri
	t.TextXAlignment  = props.align or Enum.TextXAlignment.Left
	t.Text            = props.text  or ""
	t.Size            = props.sz    or UDim2.new(1, -20, 0, 20)
	t.Position        = props.pos   or UDim2.new(0, 10, 0, 0)
	t.TextTruncate    = Enum.TextTruncate.AtEnd
	t.Parent          = parent
	return t
end

