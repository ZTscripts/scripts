local function LaunchUniversalFPS()
    local Menu = CreateGameMenu()
    
    local CombatTab   = Menu.CreateTab("Combat")
    local VisualsTab  = Menu.CreateTab("Visuals")
    local SettingsTab = Menu.CreateTab("Settings")
    
    local Players = game:GetService("Players")
    local RunService = game:GetService("RunService")
    local UserInputService = game:GetService("UserInputService")
    local LocalPlayer = Players.LocalPlayer

    local aimbotEnabled      = false
    local wallCheckEnabled    = true
    local teamCheckEnabled    = true
    local aimSmoothness       = 5
    local aimRadius          = 150
    local fovVisible         = false
    local aimTargetPart      = "Head"

    local ESP_THICK        = 2
    local MAX_ESP_DISTANCE = 1000
    local boxEspEnabled    = false
    local nameEspEnabled   = false

    local COLOR_PRESETS = {
        {name = "Crimson Red", color = Color3.fromRGB(255, 50, 50)},
        {name = "Neon Mint",   color = Color3.fromRGB(0, 255, 140)},
        {name = "Deep Blue",   color = Color3.fromRGB(0, 160, 255)},
        {name = "Pure White",  color = Color3.fromRGB(255, 255, 255)}
    }

    local boxColorIdx  = 1 
    local nameColorIdx = 4 
    local ESP_COLOR      = COLOR_PRESETS[boxColorIdx].color
    local ESP_NAME_COL   = COLOR_PRESETS[nameColorIdx].color

    local mainRenderConn  = nil
    local fovCircleDraw   = nil
    local espRenderConn   = nil
    local espData         = {}

    pcall(function()
        if Drawing and Drawing.new then
            fovCircleDraw = Drawing.new("Circle")
            fovCircleDraw.Thickness = 1
            fovCircleDraw.NumSides = 60
            fovCircleDraw.Filled = false
            fovCircleDraw.Color = Color3.fromRGB(255, 255, 255)
            fovCircleDraw.Visible = false
        end
    end)

    function getClosestPlayerInstance()
        local target = nil
        local shortestDistance = math.huge
        local camera = workspace.CurrentCamera
        if not camera then return nil end
        
        local mouseLocation = UserInputService:GetMouseLocation()

        for _, player in pairs(Players:GetPlayers()) do
            if player == LocalPlayer then continue end
            if teamCheckEnabled and player.Team == LocalPlayer.Team then continue end

            local char = player.Character
            local part = char and char:FindFirstChild(aimTargetPart)
            local hum  = char and char:FindFirstChildOfClass("Humanoid")

            if part and hum and hum.Health > 0 then
                local screenPos, onScreen = camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local distance = (Vector2.new(screenPos.X, screenPos.Y) - mouseLocation).Magnitude
                    if distance < shortestDistance and distance <= aimRadius then
                        if wallCheckEnabled then
                            local raycastParams = RaycastParams.new()
                            raycastParams.FilterType = Enum.RaycastFilterType.Exclude
                            raycastParams.FilterDescendantsInstances = {LocalPlayer.Character, char, camera}
                            raycastParams.IgnoreWater = true
                            
                            local rayResult = workspace:Raycast(camera.CFrame.Position, part.Position - camera.CFrame.Position, raycastParams)
                            if rayResult and rayResult.Instance and not rayResult.Instance:IsDescendantOf(char) then 
                                continue 
                            end
                        end

                        target = part
                        shortestDistance = distance
                    end
                end
            end
        end
        return target
    end

    function getClosestPlayerScreen()
        local targetPart = getClosestPlayerInstance()
        if targetPart then
            local camera = workspace.CurrentCamera
            local screenPos, _ = camera:WorldToViewportPoint(targetPart.Position)
            return screenPos
        end
        return nil
    end

    function systemUpdate()
        local camera = workspace.CurrentCamera
        if not camera then return end

        if fovCircleDraw then
            fovCircleDraw.Position = UserInputService:GetMouseLocation()
            fovCircleDraw.Radius = aimRadius
            fovCircleDraw.Visible = fovVisible
        end

        local isRightClickActive = UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)

        if aimbotEnabled and isRightClickActive then
            local targetScreenPos = getClosestPlayerScreen()
            if targetScreenPos and mousemoverel then
                local mouseLocation = UserInputService:GetMouseLocation()
                local deltaX = (targetScreenPos.X - mouseLocation.X) / aimSmoothness
                local deltaY = (targetScreenPos.Y - mouseLocation.Y) / aimSmoothness
                mousemoverel(deltaX, deltaY)
            end
        end
    end

    function manageConnections()
        if aimbotEnabled or fovVisible then
            if not mainRenderConn then mainRenderConn = RunService.RenderStepped:Connect(systemUpdate) end
        else
            if mainRenderConn then mainRenderConn:Disconnect(); mainRenderConn = nil end
            if fovCircleDraw then fovCircleDraw.Visible = false end
        end
    end

    function buildESPFrame(player)
        local holder = Instance.new("Frame")
        holder.Name = "ESP_" .. player.Name
        holder.BackgroundTransparency = 1
        holder.BorderSizePixel = 0
        holder.Size = UDim2.new(0, 0, 0, 0)
        holder.Parent = ScreenGui

        local function makeLine()
            local f = Instance.new("Frame")
            f.BackgroundColor3 = ESP_COLOR
            f.BorderSizePixel = 0
            f.ZIndex = 21
            f.Parent = holder
            return f
        end

        local nameTag = Instance.new("TextLabel")
        nameTag.BackgroundTransparency = 1
        nameTag.TextColor3 = ESP_NAME_COL
        nameTag.TextStrokeTransparency = 0.5
        nameTag.Font = Enum.Font.GothamBold
        nameTag.TextSize = 11
        nameTag.Text = player.Name
        nameTag.Size = UDim2.new(0, 120, 0, 14)
        nameTag.TextXAlignment = Enum.TextXAlignment.Center
        nameTag.ZIndex = 22
        nameTag.Visible = false
        nameTag.Parent = ScreenGui

        return { holder = holder, top = makeLine(), bot = makeLine(), left = makeLine(), right = makeLine(), nameTag = nameTag }
    end

    function destroyESPFor(player)
        local d = espData[player]
        if not d then return end
        if d.holder  and d.holder.Parent  then d.holder:Destroy()  end
        if d.nameTag and d.nameTag.Parent then d.nameTag:Destroy() end
        espData[player] = nil
    end

    function updateESP()
        local camera = workspace.CurrentCamera
        if not camera then return end

    for cachedPlayer, _ in pairs(espData) do
        local success, exists = pcall(function()
            return cachedPlayer and cachedPlayer.Parent and Players:FindFirstChild(cachedPlayer.Name)
        end)
        
        if not success or not exists then
            destroyESPFor(cachedPlayer)
        end
    end

        for _, player in pairs(Players:GetPlayers()) do
            if player == LocalPlayer then continue end

            local char = player.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")

            if not char or not hrp then
                local d = espData[player]
                if d then d.holder.Visible = false; d.nameTag.Visible = false end
                continue
            end

            if not espData[player] then espData[player] = buildESPFrame(player) end
            local d = espData[player]

            local pos = hrp.Position
            local topSP = camera:WorldToViewportPoint(pos + Vector3.new(0, 3.5, 0))
            local botSP = camera:WorldToViewportPoint(pos - Vector3.new(0, 3.2, 0))

            if topSP.Z > 0 and botSP.Z > 0 then
                local topY = math.min(topSP.Y, botSP.Y)
                local botY = math.max(topSP.Y, botSP.Y)
                local h = botY - topY
                local w = h * 0.45
                local x = (topSP.X + botSP.X) / 2 - (w / 2)

                local t = ESP_THICK
                d.top.BackgroundColor3 = ESP_COLOR
                d.bot.BackgroundColor3 = ESP_COLOR
                d.left.BackgroundColor3 = ESP_COLOR
                d.right.BackgroundColor3 = ESP_COLOR
                d.nameTag.TextColor3 = ESP_NAME_COL

                d.holder.Position = UDim2.new(0, x, 0, topY)
                d.holder.Size = UDim2.new(0, w, 0, h)
                d.holder.Visible = boxEspEnabled

                if boxEspEnabled then
                    d.top.Size = UDim2.new(1, 0, 0, t); d.top.Position = UDim2.new(0, 0, 0, 0)
                    d.bot.Size = UDim2.new(1, 0, 0, t); d.bot.Position = UDim2.new(0, 0, 1, -t)
                    d.left.Size = UDim2.new(0, t, 1, 0); d.left.Position = UDim2.new(0, 0, 0, 0)
                    d.right.Size = UDim2.new(0, t, 1, 0); d.right.Position = UDim2.new(1, -t, 0, 0)
                end

                d.nameTag.Position = UDim2.new(0, x + (w / 2) - 60, 0, topY - 16)
                d.nameTag.Visible = nameEspEnabled
            else
                d.holder.Visible = false
                d.nameTag.Visible = false
            end
        end
    end

    function manageESPState()
        if boxEspEnabled or nameEspEnabled then
            if not espRenderConn then espRenderConn = RunService.RenderStepped:Connect(updateESP) end
        else
            if espRenderConn then espRenderConn:Disconnect(); espRenderConn = nil end
            for player, _ in pairs(espData) do destroyESPFor(player) end
            espData = {}
        end
    end

    Menu.AddHeader(CombatTab, "Aim")
    Menu.AddToggle(CombatTab, "Enable Aimbot", false, function(s) aimbotEnabled = s; manageConnections() end)
    Menu.AddToggle(CombatTab, "Team Check", true, function(s) teamCheckEnabled = s end)
    Menu.AddToggle(CombatTab, "Wall Check", true, function(s) wallCheckEnabled = s end)
    Menu.AddToggle(CombatTab, "Show FOV Circle", false, function(s) fovVisible = s; manageConnections() end)
    
    Menu.AddHeader(CombatTab, "Target Selection")
    for _, part in ipairs({"Head", "HumanoidRootPart", "UpperTorso"}) do
        Menu.AddButton(CombatTab, "Aim Target: " .. part, function() aimTargetPart = part end)
    end
    Menu.AddSlider(CombatTab, "FOV Radius", 30, 500, aimRadius, function(v) aimRadius = v end)
    Menu.AddSlider(CombatTab, "Aimbot Smoothness (Lower=Faster)", 1, 20, aimSmoothness, function(v) aimSmoothness = v end)

    Menu.AddHeader(VisualsTab, "ESP")
    Menu.AddToggle(VisualsTab, "2D Box ESP", false, function(state) boxEspEnabled = state; manageESPState() end)
    Menu.AddToggle(VisualsTab, "Name ESP", false, function(state) nameEspEnabled = state; manageESPState() end)

    Menu.AddHeader(SettingsTab, "ESP Configuration")
    Menu.AddSlider(SettingsTab, "Line Thickness (px)", 1, 6, ESP_THICK, function(val) ESP_THICK = val end)
    Menu.AddSlider(SettingsTab, "Max Render Distance", 100, 3000, MAX_ESP_DISTANCE, function(val) MAX_ESP_DISTANCE = val end)

    local oldClose = Menu.OnClose or function() end
    Menu.OnClose = function()
        aimbotEnabled = false; fovVisible = false
        manageConnections()
        boxEspEnabled = false; nameEspEnabled = false; manageESPState()
        if fovCircleDraw then pcall(function() fovCircleDraw:Destroy() end) end
        oldClose()
    end
end

