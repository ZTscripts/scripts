        local function isPlayerAliveAndActive(player)
            if not player or player == LocalPlayer then return false end
            
            if player.Team and (player.Team.Name:lower():find("spectat") or player.Team.Name:lower():find("dead") or player.Team.Name:lower():find("lobby")) then 
                return false 
            end

            if player:GetAttribute("Spectating") == true or player:GetAttribute("IsDead") == true or player:GetAttribute("Spectator") == true then
                return false
            end
            if player:FindFirstChild("Spectating") or player:FindFirstChild("IsSpectating") or player:FindFirstChild("Spectator") then
                return false
            end
            
            local char = player.Character
            if not char or not char:IsDescendantOf(workspace) then return false end
            
            local hum = char:FindFirstChildOfClass("Humanoid")
            if not hum or hum.Health <= 0 then return false end
            
            local hrp = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Head")
            if not hrp then return false end

            if hrp.Position.Y < -500 or (workspace.CurrentCamera and (hrp.Position - workspace.CurrentCamera.CFrame.Position).Magnitude < 2) then
                return false
            end

            local head = char:FindFirstChild("Head")
            if head and head:IsA("BasePart") and head.Transparency >= 0.9 then
                return false
            end
            
            return true
        end

 
        local function updateMovement(loopTime, deltaTime)
            if spawnGracePeriod then return end

            local char = LocalPlayer.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            if not hrp or not hum then return end

            if walkSpeedEnabled and not flyEnabled then
                hum.WalkSpeed = customWalkSpeed
            end

            if jumpPowerEnabled then
                hum.UseJumpPower = true
                hum.JumpPower = customJumpPower
            end

            if noclipEnabled then
                hum:ChangeState(Enum.HumanoidStateType.NoClip)
                for _, part in ipairs(char:GetDescendants()) do
                    if part:IsA("BasePart") then
                        part.CanCollide = false
                    end
                end
            end

            if flyEnabled then
                if not flyBodyVel or flyBodyVel.Parent ~= hrp then
                    pcall(function() if flyBodyVel then flyBodyVel:Destroy() end end)
                    flyBodyVel = Instance.new("BodyVelocity")
                    flyBodyVel.Name = "StabilizedFlightVelocity"
                    flyBodyVel.Parent = hrp
                end
                
                if not flyBodyGyro or flyBodyGyro.Parent ~= hrp then
                    pcall(function() if flyBodyGyro then flyBodyGyro:Destroy() end end)
                    flyBodyGyro = Instance.new("BodyGyro")
                    flyBodyGyro.Name = "StabilizedFlightGyro"
                    flyBodyGyro.Parent = hrp
                end

                flyBodyVel.MaxForce = Vector3.new(4e5, 4e5, 4e5)
                flyBodyGyro.MaxTorque = Vector3.new(4e5, 4e5, 4e5)

                local camera = workspace.CurrentCamera
                if camera then 
                    flyBodyGyro.CFrame = camera.CFrame 
                end

                local moveDir = Vector3.zero
                
                if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                    moveDir = moveDir + camera.CFrame.LookVector
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.S) then
                    moveDir = moveDir - camera.CFrame.LookVector
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.A) then
                    moveDir = moveDir - camera.CFrame.RightVector
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.D) then
                    moveDir = moveDir + camera.CFrame.RightVector
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
                    moveDir = moveDir + Vector3.new(0, 1, 0)
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
                    moveDir = moveDir - Vector3.new(0, 1, 0)
                end

                if moveDir.Magnitude > 0 then
                    flyBodyVel.Velocity = moveDir.Unit * flySpeed
                else
                    flyBodyVel.Velocity = Vector3.zero
                end

                if hum.CurrentStateType ~= Enum.HumanoidStateType.Physics then
                    hum:ChangeState(Enum.HumanoidStateType.Physics)
                end
            end
        end

        local function manageMovementState()
            local char = LocalPlayer.Character
            local hum = char and char:FindFirstChildOfClass("Humanoid")

            if flyEnabled or noclipEnabled or walkSpeedEnabled or jumpPowerEnabled then
                if not movementConn then
                    movementConn = RunService.Stepped:Connect(updateMovement)
                end
                
                if not charAddedConn then
                    charAddedConn = LocalPlayer.CharacterAdded:Connect(function(newChar)
                        spawnGracePeriod = true
                        
                        if flyBodyVel then pcall(function() flyBodyVel:Destroy() end); flyBodyVel = nil end
                        if flyBodyGyro then pcall(function() flyBodyGyro:Destroy() end); flyBodyGyro = nil end
                        
                        task.wait(2.5)
                        spawnGracePeriod = false
                    end)
                end
            else
                if movementConn then
                    movementConn:Disconnect()
                    movementConn = nil
                end
                if charAddedConn then
                    charAddedConn:Disconnect()
                    charAddedConn = nil
                end
            end

            if not flyEnabled then
