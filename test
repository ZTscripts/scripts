        local TOP_OFFSET = 3.5   
        local BOT_OFFSET = 3.2   
        local WIDTH_RATIO = 0.45 

        local function getScreenBounds(char, camera)
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if not hrp then return nil end

            local distance = (camera.CFrame.Position - hrp.Position).Magnitude
            if distance > MAX_ESP_DISTANCE then return nil end

            local pos = hrp.Position
            local topSP = camera:WorldToViewportPoint(pos + Vector3.new(0,  TOP_OFFSET, 0))
            local botSP = camera:WorldToViewportPoint(pos - Vector3.new(0,  BOT_OFFSET, 0))

            if topSP.Z <= 0 or botSP.Z <= 0 then return nil end

            local topY = math.min(topSP.Y, botSP.Y)
            local botY = math.max(topSP.Y, botSP.Y)
            local screenH = botY - topY
            if screenH < 5 then return nil end  

            local screenW = screenH * WIDTH_RATIO
            local centerX = (topSP.X + botSP.X) / 2

            local pad = 2
            return  centerX - screenW / 2 - pad,
                    topY - pad,
                    screenW + pad * 2,
                    screenH + pad * 2
        end

        local function drawAbsoluteBone3D(lineUI, posA, posB, camera)
            if not posA or not posB or not skelEspEnabled then 
                lineUI.Visible = false 
                return 
            end

            local outA, onScreenA = camera:WorldToViewportPoint(posA)
            local outB, onScreenB = camera:WorldToViewportPoint(posB)

            if onScreenA and onScreenB and outA.Z > 0 and outB.Z > 0 then
                local startPos = Vector2.new(outA.X, outA.Y)
                local endPos = Vector2.new(outB.X, outB.Y)
                
                local distance = (endPos - startPos).Magnitude
                local midpoint = (startPos + endPos) / 2

                lineUI.Size = UDim2.new(0, ESP_THICK, 0, distance)
                lineUI.Position = UDim2.new(0, midpoint.X, 0, midpoint.Y)
                
                local angle = math.atan2(endPos.Y - startPos.Y, endPos.X - startPos.X)
                lineUI.Rotation = math.deg(angle) - 90
                lineUI.Visible = true
            else
                lineUI.Visible = false
            end
        end

        local function drawHeadNode(dotUI, headPart, camera)
            if not headPart or not skelEspEnabled then
                dotUI.Visible = false
                return
            end

            local out, onScreen = camera:WorldToViewportPoint(headPart.Position)
            if onScreen and out.Z > 0 then
                local size = math.clamp(math.round(HEAD_DOT_BASE / out.Z), 6, 45)
                dotUI.Size = UDim2.new(0, size, 0, size)
                dotUI.Position = UDim2.new(0, out.X, 0, out.Y)
                dotUI.Visible = true
            else
                dotUI.Visible = false
            end
        end

        local function updateESP()
            local camera = workspace.CurrentCamera
            if not camera then return end
            for cachedPlayer, _ in pairs(espData) do
                if not Players:FindFirstChild(cachedPlayer.Name) then
                    destroyESPFor(cachedPlayer)
                end
            end

            for _, player in pairs(Players:GetPlayers()) do
                if player == LocalPlayer then continue end

                local char = player.Character
                if not isPlayerAliveAndActive(player) then
                    local d = espData[player]
                    if d then
                        d.holder.Visible  = false
                        d.nameTag.Visible = false
                        for _, b in pairs(d.bones) do b.Visible = false end
                    end
                    continue
                end

                if not espData[player] then
                    espData[player] = buildESPFrame(player)
                end
                local d = espData[player]

                local x, y, w, h = getScreenBounds(char, camera)

                if not x then
                    d.holder.Visible  = false
                    d.nameTag.Visible = false
                    for _, b in pairs(d.bones) do b.Visible = false end
                    continue
                end

                local t = ESP_THICK

                d.top.BackgroundColor3 = ESP_COLOR
                d.bot.BackgroundColor3 = ESP_COLOR
                d.left.BackgroundColor3 = ESP_COLOR
                d.right.BackgroundColor3 = ESP_COLOR
                d.nameTag.TextColor3 = ESP_NAME_COL

                for _, boneObj in pairs(d.bones) do
                    boneObj.BackgroundColor3 = ESP_SKEL_COLOR
                end

                d.holder.Position = UDim2.new(0, x, 0, y)
                d.holder.Size     = UDim2.new(0, w, 0, h)
                d.holder.Visible  = boxEspEnabled

                if boxEspEnabled then
                    d.top.Position = UDim2.new(0, 0, 0, 0); d.top.Size = UDim2.new(1, 0, 0, t)
                    d.bot.Position = UDim2.new(0, 0, 1, -t); d.bot.Size = UDim2.new(1, 0, 0, t)
                    d.left.Position = UDim2.new(0, 0, 0, 0); d.left.Size = UDim2.new(0, t, 1, 0)
                    d.right.Position = UDim2.new(1, -t, 0, 0); d.right.Size = UDim2.new(0, t, 1, 0)
                end

                d.nameTag.Position = UDim2.new(0, x + w / 2 - 60, 0, y - 16)
                d.nameTag.Visible  = nameEspEnabled

                if skelEspEnabled then
                    local head = char:FindFirstChild("Head")
                    local torso = char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
                    local lowerTorso = char:FindFirstChild("LowerTorso")
                    
                    local RigsFolder = char:FindFirstChild("Rigs") or char:FindFirstChild("Limbs")
                    
                    local lArm = char:FindFirstChild("Left Arm") or char:FindFirstChild("LeftUpperArm") or (RigsFolder and RigsFolder:FindFirstChild("Left Arm"))
                    local lForearm = char:FindFirstChild("LeftLowerArm")
                    local rArm = char:FindFirstChild("Right Arm") or char:FindFirstChild("RightUpperArm") or (RigsFolder and RigsFolder:FindFirstChild("Right Arm"))
                    local rForearm = char:FindFirstChild("RightLowerArm")
                    
                    local lLeg = char:FindFirstChild("Left Leg") or char:FindFirstChild("LeftUpperLeg") or (RigsFolder and RigsFolder:FindFirstChild("Left Leg"))
                    local lShin = char:FindFirstChild("LeftLowerLeg")
                    local rLeg = char:FindFirstChild("Right Leg") or char:FindFirstChild("RightUpperLeg") or (RigsFolder and RigsFolder:FindFirstChild("Right Leg"))
                    local rShin = char:FindFirstChild("RightLowerLeg")

                    drawHeadNode(d.bones.HeadDot, head, camera)

                    if head and torso then
                        drawAbsoluteBone3D(d.bones.HeadToTorso, head.Position, torso.Position, camera)

                        if lowerTorso then
                            drawAbsoluteBone3D(d.bones.LowerTorso, torso.Position, lowerTorso.Position, camera)
                            if lArm     then drawAbsoluteBone3D(d.bones.TorsoToLeftArm, torso.Position, lArm.Position, camera) end
                            if lForearm then drawAbsoluteBone3D(d.bones.LeftArmToForearm, lArm.Position, lForearm.Position, camera) end
                            if rArm     then drawAbsoluteBone3D(d.bones.TorsoToRightArm, torso.Position, rArm.Position, camera) end
                            if rForearm then drawAbsoluteBone3D(d.bones.RightArmToForearm, rArm.Position, rForearm.Position, camera) end
                            if lLeg  then drawAbsoluteBone3D(d.bones.TorsoToLeftLeg, lowerTorso.Position, lLeg.Position, camera) end
                            if lShin then drawAbsoluteBone3D(d.bones.LeftLegToShin, lLeg.Position, lShin.Position, camera) end
                            if rLeg  then drawAbsoluteBone3D(d.bones.TorsoToRightLeg, lowerTorso.Position, rLeg.Position, camera) end
                            if rShin then drawAbsoluteBone3D(d.bones.RightLegToShin, rLeg.Position, rShin.Position, camera) end
                        else
                            d.bones.LowerTorso.Visible = false
                            
                            if lArm then
                                local armTop = lArm.Position + Vector3.new(0, 1, 0)
                                local armBot = lArm.Position - Vector3.new(0, 1.4, 0)
                                drawAbsoluteBone3D(d.bones.TorsoToLeftArm, torso.Position + Vector3.new(-1, 1, 0), armTop, camera)
                                drawAbsoluteBone3D(d.bones.LeftArmToForearm, armTop, armBot, camera)
                            end
                            if rArm then
                                local armTop = rArm.Position + Vector3.new(0, 1, 0)
                                local armBot = rArm.Position - Vector3.new(0, 1.4, 0)
                                drawAbsoluteBone3D(d.bones.TorsoToRightArm, torso.Position + Vector3.new(1, 1, 0), armTop, camera)
                                drawAbsoluteBone3D(d.bones.RightArmToForearm, armTop, armBot, camera)
                            end
                            if lLeg then
                                local legTop = lLeg.Position + Vector3.new(0, 1, 0)
                                local legBot = lLeg.Position - Vector3.new(0, 1.2, 0)
                                drawAbsoluteBone3D(d.bones.TorsoToLeftLeg, torso.Position + Vector3.new(-0.5, -1, 0), legTop, camera)
                                drawAbsoluteBone3D(d.bones.LeftLegToShin, legTop, legBot, camera)
                            end
                            if rLeg then
                                local legTop = rLeg.Position + Vector3.new(0, 1, 0)
                                local legBot = rLeg.Position - Vector3.new(0, 1.2, 0)
