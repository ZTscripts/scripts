function MenuAPI.AddSlider(page, text, min, max, default, cb)
		local currentOrder = page:GetAttribute("CurrentLayoutOrder") or 1
		local value = default or min
		
		local card = Instance.new("Frame")
		card.Size = UDim2.new(1, 0, 0, 48)
		card.BackgroundColor3 = C.bg3
		card.LayoutOrder = currentOrder
		card.Parent = page
