[122446657157717] = {
    name = "Sniper Arena",
    placeId = 122446657157717,
    callback = function()
        local Menu = CreateGameMenu()
        local CombatTab = Menu.CreateTab("Combat")
        local VisualsTab = Menu.CreateTab("Visuals")
        local MovementTab = Menu.CreateTab("Movement")
        local MiscTab = Menu.CreateTab("Misc")
        local RunService = game:GetService("RunService")
        local UserInputService = game:GetService("UserInputService")
        local ReplicatedStorage = game:GetService("ReplicatedStorage")
        local Players = game:GetService("Players")
        local LocalPlayer = Players.LocalPlayer
        local aimbotEnabled = false
        local silentAimEnabled = false
        local triggerbotEnabled = false
        local wallCheck = true
        local teamCheck = true
        local aimPart = "Head"
        local aimSmoothness = 8
        local fovRadius = 150
        local flyEnabled = false
        local flySpeed = 25
        local noclipEnabled = false
        local function getRemotes()
            local remotes = {}
            for _, v in ipairs(ReplicatedStorage:GetDescendants()) do
                if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") then
                    if v.Name:lower():find("shoot") or v.Name:lower():find("fire") or
                       v.Name:lower():find("bullet") or v.Name:lower():find("hit") then
                        table.insert(remotes, v)
                    end
                end
            end
            return remotes
        end
        local shootRemote = nil
        task.spawn(function()
            local found = getRemotes()
            if #found > 0 then
                shootRemote = found[1]
                showToast("Remotes", "Found shooting remote: " .. shootRemote.Name, "info")
            end
        end)
        local bodyVelocity
        local function toggleFly(state)
            flyEnabled = state
            local char = LocalPlayer.Character
            if not char then return end
            local root = char:FindFirstChild("HumanoidRootPart")
            if not root then return end
            if state then
                bodyVelocity = Instance.new("BodyVelocity")
                bodyVelocity.MaxForce = Vector3.new(1e5, 1e5, 1e5)
                bodyVelocity.Velocity = Vector3.new(0,0,0)
                bodyVelocity.Parent = root
                RunService.RenderStepped:Connect(function()
                    if not flyEnabled or not bodyVelocity then return end
                    local cam = workspace.CurrentCamera
                    local moveDir = Vector3.new()
                    if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + cam.CFrame.LookVector end
                    if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - cam.CFrame.LookVector end
                    if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - cam.CFrame.RightVector end
                    if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + cam.CFrame.RightVector end
                    if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDir = moveDir + Vector3.new(0,1,0) end
                    if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then moveDir = moveDir - Vector3.new(0,1,0) end
                    bodyVelocity.Velocity = moveDir.Unit * flySpeed * 10
                end)
            else
                if bodyVelocity then bodyVelocity:Destroy() end
            end
        end
        local noclipConn
        local function toggleNoclip(state)
            noclipEnabled = state
            if state then
                noclipConn = RunService.Stepped:Connect(function()
                    local char = LocalPlayer.Character
                    if char then
                        for _, part in pairs(char:GetDescendants()) do
                            if part:IsA("BasePart") then
                                part.CanCollide = false
                            end
                        end
                    end
                end)
            else
                if noclipConn then noclipConn:Disconnect() end
            end
        end
        local function getClosestPlayer()
            local closest, dist = nil, math.huge
            local mousePos = UserInputService:GetMouseLocation()
            local cam = workspace.CurrentCamera
            for _, plr in pairs(Players:GetPlayers()) do
                if plr == LocalPlayer or (teamCheck and plr.Team == LocalPlayer.Team) then continue end
                local char = plr.Character
                if not char then continue end
                local hum = char:FindFirstChildOfClass("Humanoid")
                local part = char:FindFirstChild(aimPart)
                if not hum or hum.Health <= 0 or not part then continue end
                local screenPos, onScreen = cam:WorldToViewportPoint(part.Position)
                if not onScreen then continue end
                local screenDist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                if screenDist > fovRadius then continue end
                if wallCheck then
                    local ray = workspace:Raycast(cam.CFrame.Position, (part.Position - cam.CFrame.Position).Unit * 1000)
                    if ray and ray.Instance and not ray.Instance:IsDescendantOf(char) then
                        continue
                    end
                end
                if screenDist < dist then
                    dist = screenDist
                    closest = part
                end
            end
            return closest
        end
        local aimConn
        local function updateAimbot()
            if not aimbotEnabled then return end
            local part = getClosestPlayer()
            if not part then return end
            local cam = workspace.CurrentCamera
            local targetCFrame = CFrame.new(cam.CFrame.Position, part.Position)
            cam.CFrame = cam.CFrame:Lerp(targetCFrame, 1 / aimSmoothness)
        end
        local oldNamecall
        oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
            local args = {...}
            local method = getnamecallmethod()
            if silentAimEnabled and method == "FireServer" and shootRemote and self == shootRemote then
                local targetPart = getClosestPlayer()
                if targetPart then
                    if args[1] and typeof(args[1]) == "Vector3" then
                        args[1] = targetPart.Position + targetPart.Velocity * 0.1
                    end
                    return oldNamecall(self, unpack(args))
                end
            end
            return oldNamecall(self, ...)
        end)
        local triggerConn
        local function triggerbotLoop()
            while triggerbotEnabled do
                task.wait(0.03)
                local targetPart = getClosestPlayer()
                if targetPart and shootRemote then
                    shootRemote:FireServer()
                end
            end
        end
        Menu.AddHeader(CombatTab, "Aimbot Settings")
        Menu.AddToggle(CombatTab, "Aimbot (Right Click)", false, function(s)
            aimbotEnabled = s
            if s and not aimConn then
                aimConn = RunService.RenderStepped:Connect(updateAimbot)
            elseif not s and aimConn then
                aimConn:Disconnect()
                aimConn = nil
            end
        end)
        Menu.AddToggle(CombatTab, "Silent Aim", false, function(s) silentAimEnabled = s end)
        Menu.AddToggle(CombatTab, "Trigger Bot", false, function(s)
            triggerbotEnabled = s
            if s and not triggerConn then
                triggerConn = task.spawn(triggerbotLoop)
            elseif not s and triggerConn then
                triggerConn = nil
            end
        end)
        Menu.AddToggle(CombatTab, "Team Check", true, function(s) teamCheck = s end)
        Menu.AddToggle(CombatTab, "Wall Check", true, function(s) wallCheck = s end)
        Menu.AddHeader(CombatTab, "Aim Part")
        for _, part in ipairs({"Head", "HumanoidRootPart", "UpperTorso"}) do
            Menu.AddButton(CombatTab, "Aim at " .. part, function()
                aimPart = part
                showToast("Aim Part", "Now aiming at: " .. part, "info")
            end)
        end
        Menu.AddSlider(CombatTab, "FOV", 30, 500, fovRadius, function(v) fovRadius = v end)
        Menu.AddSlider(CombatTab, "Smoothness", 1, 20, aimSmoothness, function(v) aimSmoothness = v end)
        Menu.AddHeader(MovementTab, "Movement")
        Menu.AddToggle(MovementTab, "Fly (Hold Right Click or use keys)", false, toggleFly)
        Menu.AddSlider(MovementTab, "Fly Speed", 10, 100, flySpeed, function(v) flySpeed = v end)
        Menu.AddToggle(MovementTab, "Noclip", false, toggleNoclip)
        local oldClose = Menu.OnClose or function() end
        Menu.OnClose = function()
            aimbotEnabled = false
            silentAimEnabled = false
            triggerbotEnabled = false
            flyEnabled = false
            noclipEnabled = false
            if aimConn then aimConn:Disconnect() end
            if noclipConn then noclipConn:Disconnect() end
            oldClose()
        end
        showToast("Sniper Arena", "Loaded combat features!", "info")
    end
},

