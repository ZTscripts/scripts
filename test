            local function getClosestPlayerToMouth()
                local target = nil
                local shortestDistance = math.huge
                local camera = workspace.CurrentCamera
                local mouseLocation = UserInputService:GetMouseLocation()

                if not camera then return nil end

                for _, player in pairs(Players:GetPlayers()) do
                    if player == LocalPlayer then continue end
                    local char = player.Character
                    local part = char and char:FindFirstChild(aimTargetPart)
                    local hum  = char and char:FindFirstChildOfClass("Humanoid")

                    if part and hum and hum.Health > 0 then
                        local screenPos, onScreen = camera:WorldToViewportPoint(part.Position)
                        if onScreen then
                            local distance = (Vector2.new(screenPos.X, screenPos.Y) - mouseLocation).Magnitude
                            if distance < shortestDistance and distance <= aimRadius then
                                
                                if wallCheckEnabled then
                                    local isBlocked = false
                                    local origin = camera.CFrame.Position
                                    local direction = (part.Position - origin)
                                    
                                    local raycastParams = RaycastParams.new()
                                    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
                                    local ignoreList = {LocalPlayer.Character, char, camera}
                                    raycastParams.FilterDescendantsInstances = ignoreList
                                    raycastParams.IgnoreWater = true

                                    while true do
                                        local raycastResult = workspace:Raycast(origin, direction, raycastParams)
                                        if not raycastResult then
                                            break 
                                        end

                                        local hitInstance = raycastResult.Instance
                                        if hitInstance and (hitInstance.Transparency > 0.5 or hitInstance.CanCollide == false) then
                                            table.insert(ignoreList, hitInstance)
                                            raycastParams.FilterDescendantsInstances = ignoreList
                                        else
                                            isBlocked = true
                                            break
                                        end
                                    end

                                    if isBlocked then 
                                        continue 
                                    end
                                end

                                target = part
                                shortestDistance = distance
                            end
                        end
                    end
                end
                return target
            end

            local function handleAimSystemUpdate()
                local camera = workspace.CurrentCamera
                if not camera then return end

                if fovCircleDraw then
                    fovCircleDraw.Position = UserInputService:GetMouseLocation()
                    fovCircleDraw.Radius = aimRadius
                    fovCircleDraw.Visible = fovVisible
                end

                if not aimbotEnabled then return end
                if not isRightClickHolding then return end

                local targetPart = getClosestPlayerToMouth()
                if targetPart then
                    local lookCFrame = CFrame.new(camera.CFrame.Position, targetPart.Position)
                    if aimSmoothness <= 1 then
                        camera.CFrame = lookCFrame
                    else
                        camera.CFrame = camera.CFrame:Lerp(lookCFrame, 1 / aimSmoothness)
                    end
                end
            end

