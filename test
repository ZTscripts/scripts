		stroke(card, C.border)

		local tlbl = Instance.new("TextLabel")
		tlbl.Size = UDim2.new(1, -120, 0, 20)
		tlbl.Position = UDim2.new(0, 12, 0, 4)
		tlbl.BackgroundTransparency = 1
		tlbl.Text = text
		tlbl.TextColor3 = C.textPri
		tlbl.Font = Enum.Font.GothamSemibold
		tlbl.TextSize = 12
		tlbl.TextXAlignment = Enum.TextXAlignment.Left
		tlbl.Parent = card

		local vlbl = Instance.new("TextLabel")
		vlbl.Size = UDim2.new(0, 80, 0, 20)
		vlbl.Position = UDim2.new(1, -92, 0, 4)
		vlbl.BackgroundTransparency = 1
		vlbl.Text = tostring(value)
		vlbl.TextColor3 = C.textSec
		vlbl.Font = Enum.Font.Code
		vlbl.TextSize = 11
		vlbl.TextXAlignment = Enum.TextXAlignment.Right
		vlbl.Parent = card

		local track = Instance.new("TextButton")
		track.Size = UDim2.new(1, -24, 0, 6)
		track.Position = UDim2.new(0, 12, 1, -14)
		track.BackgroundColor3 = C.bg4
		track.Text = ""
		track.Parent = card
		corner(track, 3)

		local fill = Instance.new("Frame")
		fill.Size = UDim2.new((value - min) / (max - min), 0, 1, 0)
		fill.BackgroundColor3 = C.accent
		fill.BorderSizePixel = 0
		fill.Parent = track
		corner(fill, 3)

		local knob = Instance.new("Frame")
		knob.Size = UDim2.new(0, 12, 0, 12)
		knob.AnchorPoint = Vector2.new(0.5, 0.5)
		knob.Position = UDim2.new((value - min) / (max - min), 0, 0.5, 0)
		knob.BackgroundColor3 = C.textPri
		knob.Parent = track
		corner(knob, 6)
		stroke(knob, C.bg0, 1.5)

		local UserInputService = game:GetService("UserInputService")
		local dragging = false

		local function updateSlider(input)
			local trackWidth = track.AbsoluteSize.X
			local clickX = input.Position.X - track.AbsolutePosition.X
			local percentage = math.clamp(clickX / trackWidth, 0, 1)
			
			value = math.round(min + (percentage * (max - min)))
			
			vlbl.Text = tostring(value)
			fill.Size = UDim2.new(percentage, 0, 1, 0)
			knob.Position = UDim2.new(percentage, 0, 0.5, 0)
			
			task.spawn(cb, value)
		end

		track.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				dragging = true
				updateSlider(input)
			end
		end)

		UserInputService.InputChanged:Connect(function(input)
			if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
				updateSlider(input)
			end
		end)

		UserInputService.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				dragging = false
			end
		end)

		page:SetAttribute("CurrentLayoutOrder", currentOrder + 1)
