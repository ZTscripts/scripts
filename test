        function buildESPFrame(player)
            local holder = Instance.new("Frame")
            holder.Name = "ESP_" .. player.Name
            holder.BackgroundTransparency = 1
            holder.BorderSizePixel = 0
            holder.Size = UDim2.new(0, 0, 0, 0)
            holder.Parent = ScreenGui

            local function makeLine()
                local f = Instance.new("Frame")
                f.BackgroundColor3 = ESP_COLOR
                f.BorderSizePixel = 0
                f.ZIndex = 21
                f.Parent = holder
                return f
            end

            local nameTag = Instance.new("TextLabel")
            nameTag.BackgroundTransparency = 1
            nameTag.TextColor3 = ESP_NAME_COL
            nameTag.TextStrokeTransparency = 0.5
            nameTag.Font = Enum.Font.GothamBold
            nameTag.TextSize = 11
            nameTag.Text = player.Name
            nameTag.Size = UDim2.new(0, 120, 0, 14)
            nameTag.TextXAlignment = Enum.TextXAlignment.Center
            nameTag.ZIndex = 22
            nameTag.Visible = false
            nameTag.Parent = ScreenGui

            return {
                holder = holder,
                top = makeLine(),
                bot = makeLine(),
                left = makeLine(),
                right = makeLine(),
                nameTag = nameTag
            }
        end

        function destroyESPFor(player)
            local d = espData[player]
            if not d then return end
            if d.holder  and d.holder.Parent  then d.holder:Destroy()  end
            if d.nameTag and d.nameTag.Parent then d.nameTag:Destroy() end
            espData[player] = nil
        end

        function updateESP()
            local camera = workspace.CurrentCamera
            if not camera then return end

            for cachedPlayer, _ in pairs(espData) do
                if not Players:FindFirstChild(cachedPlayer.Name) then
                    destroyESPFor(cachedPlayer)
                end
            end

            for _, player in pairs(Players:GetPlayers()) do
                if player == LocalPlayer then continue end

                if not isPlayerAliveAndActive(player) then
                    local d = espData[player]
                    if d then
                        d.holder.Visible = false
                        d.nameTag.Visible = false
                    end
                    continue
                end

                local char = player.Character
                local hrp = char:FindFirstChild("HumanoidRootPart")

                if not espData[player] then espData[player] = buildESPFrame(player) end
                local d = espData[player]

                local pos = hrp.Position
                local distance = (camera.CFrame.Position - pos).Magnitude
                if distance > MAX_ESP_DISTANCE then
                    d.holder.Visible = false
                    d.nameTag.Visible = false
                    continue
                end

                local topSP = camera:WorldToViewportPoint(pos + Vector3.new(0, 3.5, 0))
                local botSP = camera:WorldToViewportPoint(pos - Vector3.new(0, 3.2, 0))

                if topSP.Z > 0 and botSP.Z > 0 then
                    local topY = math.min(topSP.Y, botSP.Y)
                    local botY = math.max(topSP.Y, botSP.Y)
                    local h = botY - topY
                    local w = h * 0.45
                    local x = (topSP.X + botSP.X) / 2 - (w / 2)

                    local t = ESP_THICK
                    d.top.BackgroundColor3 = ESP_COLOR
                    d.bot.BackgroundColor3 = ESP_COLOR
                    d.left.BackgroundColor3 = ESP_COLOR
                    d.right.BackgroundColor3 = ESP_COLOR
                    d.nameTag.TextColor3 = ESP_NAME_COL

                    d.holder.Position = UDim2.new(0, x, 0, topY)
                    d.holder.Size = UDim2.new(0, w, 0, h)
                    d.holder.Visible = boxEspEnabled

                    if boxEspEnabled then
                        d.top.Size = UDim2.new(1, 0, 0, t); d.top.Position = UDim2.new(0, 0, 0, 0)
                        d.bot.Size = UDim2.new(1, 0, 0, t); d.bot.Position = UDim2.new(0, 0, 1, -t)
                        d.left.Size = UDim2.new(0, t, 1, 0); d.left.Position = UDim2.new(0, 0, 0, 0)
                        d.right.Size = UDim2.new(0, t, 1, 0); d.right.Position = UDim2.new(1, -t, 0, 0)
                    end

                    d.nameTag.Position = UDim2.new(0, x + (w / 2) - 60, 0, topY - 16)
                    d.nameTag.Visible = nameEspEnabled
                else
                    d.holder.Visible = false
                    d.nameTag.Visible = false
                end
            end
        end

        function manageESPState()
            if boxEspEnabled or nameEspEnabled then
                if not espRenderConn then espRenderConn = RunService.RenderStepped:Connect(updateESP) end
            else
                if espRenderConn then espRenderConn:Disconnect(); espRenderConn = nil end
                for player, _ in pairs(espData) do destroyESPFor(player) end
                espData = {}
            end
        end

        Menu.AddHeader(CombatTab, "Aim")
        Menu.AddToggle(CombatTab, "Enable Aimbot", false, function(s) aimbotEnabled = s; manageConnections() end)
        Menu.AddToggle(CombatTab, "Enable Right-Click Triggerbot", false, function(s) triggerbotEnabled = s; manageConnections() end)
        Menu.AddToggle(CombatTab, "Team Check", true, function(s) teamCheckEnabled = s end)
        Menu.AddToggle(CombatTab, "Wall Check", true, function(s) wallCheckEnabled = s end)
        Menu.AddToggle(CombatTab, "Show FOV Circle", false, function(s) fovVisible = s; manageConnections() end)
        
        Menu.AddHeader(CombatTab, "Target Selection")
        for _, part in ipairs({"Head", "HumanoidRootPart", "UpperTorso"}) do
            Menu.AddButton(CombatTab, "Aim Target: " .. part, function() aimTargetPart = part end)
        end
        Menu.AddSlider(CombatTab, "FOV Radius", 30, 500, aimRadius, function(v) aimRadius = v end)
        Menu.AddSlider(CombatTab, "Aimbot Smoothness (Lower=Faster)", 1, 20, aimSmoothness, function(v) aimSmoothness = v end)

        Menu.AddHeader(VisualsTab, "ESP")
        Menu.AddToggle(VisualsTab, "2D Box ESP", false, function(state) boxEspEnabled = state; manageESPState() end)
        Menu.AddToggle(VisualsTab, "Name ESP", false, function(state) nameEspEnabled = state; manageESPState() end)

--[[
        Menu.AddHeader(MovementTab, "Movement Options")
        Menu.AddToggle(MovementTab, "Flight Toggle (Stabilized)", false, toggleFly)
        Menu.AddSlider(MovementTab, "Flight Mode Velocity Speed", 10, 150, flySpeed, function(v) flySpeed = v end)
        Menu.AddToggle(MovementTab, "Global Object Noclip", false, toggleNoclip)
        Menu.AddToggle(MovementTab, "Custom WalkSpeed Modifier", false, toggleWalkSpeed)
        Menu.AddSlider(MovementTab, "WalkSpeed Intensity", 16, 3000, customWalkSpeed, function(v) customWalkSpeed = v end)
        Menu.AddToggle(MovementTab, "Custom JumpPower Modifier", false, toggleJumpPower)
